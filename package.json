{
  "name": "expo-native-emojis-popup",
  "version": "1.0.2",
  "description": "A fully native emoji reaction popup for React Native. Built with Swift (iOS) and Kotlin (Android) for 60+ FPS animations. Anchor-based positioning, long-press drag-to-select, haptic feedback, hover labels, and fully customizable styling.",
  "main": "lib/commonjs/index.js",
  "module": "lib/module/index.js",
  "types": "lib/typescript/index.d.ts",
  "react-native": "src/index.ts",
  "source": "src/index.ts",
  "scripts": {
    "build": "bob build",
    "clean": "del-cli lib",
    "lint": "eslint \"src/**/*.{ts,tsx}\"",
    "format": "prettier --write \"src/**/*.{ts,tsx}\"",
    "format:check": "prettier --check \"src/**/*.{ts,tsx}\"",
    "typecheck": "tsc --noEmit",
    "prepare": "lefthook install && bob build",
    "prepublishOnly": "bob build",
    "release": "release-it",
    "open:ios": "xed example/ios",
    "open:android": "open -a \"Android Studio\" example/android"
  },
  "keywords": [
    "react-native",
    "expo",
    "emoji",
    "reaction",
    "popup",
    "native",
    "ios",
    "android",
    "animation",
    "haptic",
    "drag-select",
    "long-press"
  ],
  "repository": "https://github.com/efstathiosntonas/expo-native-emojis-popup",
  "bugs": {
    "url": "https://github.com/efstathiosntonas/expo-native-emojis-popup/issues"
  },
  "author": "Efstathios Ntonas",
  "license": "MIT",
  "homepage": "https://github.com/efstathiosntonas/expo-native-emojis-popup#readme",
  "peerDependencies": {
    "expo": ">=54.0.0",
    "react": ">=18.3.1",
    "react-native": ">=0.81.0"
  },
  "devDependencies": {
    "@release-it/conventional-changelog": "^10.0.6",
    "@types/react": "~19.2.14",
    "del-cli": "6.0.0",
    "eslint": "9.0.0",
    "eslint-config-prettier": "^10.0.0",
    "expo": "~55.0.0",
    "expo-modules-core": "~55.0.16",
    "lefthook": "2.1.4",
    "prettier": "3.8.0",
    "react": "19.2.4",
    "react-native": "0.83.3",
    "react-native-builder-bob": "0.40.0",
    "release-it": "^19.2.4",
    "typescript": "~5.9.3"
  },
  "files": [
    "android/build.gradle",
    "android/src/main/AndroidManifest.xml",
    "android/src/main/java/",
    "expo-module.config.json",
    "ios/",
    "lib/",
    "llms.txt",
    "src/"
  ],
  "react-native-builder-bob": {
    "source": "src",
    "output": "lib",
    "targets": [
      [
        "commonjs",
        {
          "copyFlow": false
        }
      ],
      [
        "module",
        {
          "copyFlow": false
        }
      ],
      "typescript"
    ]
  },
  "eslintIgnore": [
    "node_modules/",
    "lib/",
    "plugin/build/",
    "example/"
  ],
  "packageManager": "yarn@4.13.0"
}
